# Server Configuration
PORT=3000
NODE_ENV=development
SEED_CLEAN=true

# MongoDB
# For local (non-Docker): mongodb://localhost:27017/farmer_survey
# For Docker Compose backend service: mongodb://mongo:27017/farmer_survey
MONGODB_URI=mongodb://localhost:27017/farmer_survey
MONGODB_DB_NAME=farmer_survey

# Auth
JWT_SECRET=change-this-jwt-secret

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_NUMBER=+15550000000
WHATSAPP_API_VERSION=v24.0
WHATSAPP_TEST_PHONE_NUMBER=+15550000000
WHATSAPP_VERIFY_TOKEN=farmer_survey_pilot_2026
WHATSAPP_WEBHOOK_URL=https://your-ngrok-or-public-url/webhook
WHATSAPP_BUSSINESS_ACCOUNT_ID=your_business_account_id
APP_ID=your_meta_app_id
WHATSAPP_API_BASE_URL=https://graph.facebook.com

# Optional invite template fallback
WHATSAPP_INVITE_TEMPLATE_NAME=
WHATSAPP_INVITE_TEMPLATE_LANG=en_US

# Bulk invite tuning (optional)
BULK_INVITE_ASYNC_THRESHOLD=50
BULK_INVITE_MAX_SIZE=1000
BULK_INVITE_BATCH_SIZE=20

# Groq AI
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0
GROQ_MAX_TOKENS=4096

# Audio Storage
AUDIO_STORAGE_PATH=./audio_storage
ENABLE_TRANSCRIPTION=true
AUDIO_RETENTION_DAYS=30

# App metadata
LOG_LEVEL=debug
APP_VERSION=1.0.0-alpha

# Admin API key (set in production)
ADMIN_API_KEY=change-this-admin-key

# Text-to-Speech
# Supported: elevenlabs | none
TTS_PROVIDER=elevenlabs
TTS_ENABLED=true
TTS_TIMEOUT_MS=60000
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_default_voice_id
ELEVENLABS_VOICE_ID_HINDI=your_hindi_voice_id
# ELEVENLABS_VOICE_ID_TELUGU=
# ELEVENLABS_VOICE_ID_KANNADA=
# ELEVENLABS_VOICE_ID_TAMIL=
# ELEVENLABS_VOICE_ID_MARATHI=
# ELEVENLABS_VOICE_ID_ENGLISH=

# Speech-to-Text
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3-turbo
STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
STT_API_KEY=your_stt_api_key
TRANSCRIPTION_CONFIDENCE_THRESHOLD=0.6
